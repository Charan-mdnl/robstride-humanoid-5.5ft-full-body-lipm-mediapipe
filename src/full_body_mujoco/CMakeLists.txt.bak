  rclcpp std_msgs sensor_msgs geometry_msgs tf2_ros tf2_geometry_msgs urdf trajectory_msgs pinocchio visualization_msgs)
target_link_libraries(zmp_control_dcm Eigen3::Eigen)
install(TARGETS zmp_control_dcm DESTINATION lib/${PROJECT_NAME})

add_executable(lipm_walker scripts/lipm_walker.cpp)
ament_target_dependencies(lipm_walker
  rclcpp std_msgs sensor_msgs geometry_msgs tf2_ros tf2_geometry_msgs urdf trajectory_msgs visualization_msgs)
target_link_libraries(lipm_walker Eigen3::Eigen)
install(TARGETS lipm_walker DESTINATION lib/${PROJECT_NAME})

add_executable(nr_ik_test scripts/nr_ik_test.cpp)
ament_target_dependencies(nr_ik_test
  rclcpp std_msgs sensor_msgs geometry_msgs tf2_ros tf2_geometry_msgs urdf trajectory_msgs visualization_msgs)
target_link_libraries(nr_ik_test Eigen3::Eigen)
install(TARGETS nr_ik_test DESTINATION lib/${PROJECT_NAME})

# Message generation
rosidl_generate_interfaces(${PROJECT_NAME}
  "msg/FootSensor.msg"
  "msg/FootSensorArray.msg"
)

ament_export_dependencies(rosidl_default_runtime)
ament_package()
