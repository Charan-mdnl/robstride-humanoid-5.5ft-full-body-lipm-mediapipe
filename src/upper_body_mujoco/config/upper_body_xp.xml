<!--
  upper_body_xp.xml
  =================
  MuJoCo scene wrapper for the upper body XP_robot model.

  This file sets the correct meshdir pointing to the XP_robot meshes directory
  so the XP_robot_upper_body.xml can be included without modification.

  The mujoco_ros2_control node points at THIS file as robot_model_path.
-->
<mujoco model="upper_body_xp">
    <!-- Resolve mesh paths relative to the XP_robot meshes directory -->
    <compiler meshdir="/home/me/clean_ws/src/XP_robot/meshes"
              angle="radian"
              inertiafromgeom="false" />

    <option gravity="0 0 -9.81" timestep="0.002" />

    <default>
        <joint damping="10" frictionloss="0.1" armature="0.5" />
        <motor ctrlrange="-1 1" ctrllimited="true" />
        <position ctrlrange="-3.1416 3.1416" ctrllimited="true" />
        <geom contype="0" conaffinity="0" />
    </default>

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0" />
        <rgba haze="0.15 0.25 0.35 1" />
        <global azimuth="160" elevation="-20" />
    </visual>

    <asset>
        <mesh name="torso"         file="torso.stl"         scale="0.001 0.001 0.001" />
        <mesh name="shoulder_pitch_r" file="shoulder_pitch_r.stl" scale="0.001 0.001 0.001" />
        <mesh name="shoulder_roll_r"  file="shoulder_roll_r.stl"  scale="0.001 0.001 0.001" />
        <mesh name="bicep_r"       file="bicep_r.stl"       scale="0.001 0.001 0.001" />
        <mesh name="forearm_r"     file="forearm_r.stl"     scale="0.001 0.001 0.001" />
        <mesh name="shoulder_pitch_l" file="shoulder_pitch_l.stl" scale="0.001 0.001 0.001" />
        <mesh name="shoulder_roll_l"  file="shoulder_roll_l.stl"  scale="0.001 0.001 0.001" />
        <mesh name="bicep_l"       file="bicep_l.stl"       scale="0.001 0.001 0.001" />
        <mesh name="forearm_l"     file="forearm_l.stl"     scale="0.001 0.001 0.001" />

        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072" />
        <texture type="2d" name="groundplane" builtin="checker" mark="edge"
                 rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300" />
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2" />
    </asset>

    <worldbody>
        <light pos="0 0 3.5" dir="0 0 -1" directional="true" />
        <geom name="floor" size="0 0 0.05" pos="0 0 0" type="plane" material="groundplane" />

        <!-- Torso fixed in world at z = 1.0 (matching URDF fixed base) -->
        <body name="torso"
              pos="0 0 1.0"
              euler="0 0 3.1415926535897913">
            <geom name="torso_geom" type="mesh" mesh="torso" pos="0 0 0" euler="0 0 0" />
            <inertial mass="7.92"
                pos="0.002 0.001 0.222"
                fullinertia="0.135 0.200 0.116 0 0 0" />

            <body name="shoulder_pitch_r"
                  pos="0.2215 -0.0042 0.2654"
                  euler="0 0 3.141592653589789">
                <joint name="shoulder_pitch_r" type="hinge"
                    axis="1.0 0.0 0.0"
                    pos="0.0755 -0.0042 0.0240"
                    range="-3.1416 3.1416" limited="true" />
                <geom name="shoulder_pitch_r_geom" type="mesh" mesh="shoulder_pitch_r" pos="0 0 0" euler="0 0 0" />
                <inertial mass="3.68"
                    pos="0.002 -0.0019 0.024"
                    fullinertia="0.0032 0.0049 0.0036 0 0 0" />
                <body name="shoulder_roll_r"
                      pos="0 -0.0022 -0.0833"
                      euler="0 0 -1.5707963267949945">
                    <joint name="shoulder_roll_r" type="hinge"
                        axis="1.0 0.0 0.0"
                        pos="0.0422 0 0.1073"
                        range="-0.0873 3.3161" limited="true" />
                    <geom name="shoulder_roll_r_geom" type="mesh" mesh="shoulder_roll_r" pos="0 0 0" euler="0 0 0" />
                    <inertial mass="1.74"
                        pos="0.0003 0 0.025"
                        fullinertia="0.0013 0.0017 0.0015 0 0 0" />
                    <body name="bicep_r"
                          pos="-0.0061 0 -0.035"
                          euler="0 0 1.5707963267948957">
                        <joint name="elbow_yaw_r" type="hinge"
                            axis="0.0 0.0 -1.0"
                            pos="0 -0.0061 0.031"
                            range="-3.1416 3.1416" limited="true" />
                        <geom name="bicep_r_geom" type="mesh" mesh="bicep_r" pos="0 0 0" euler="0 0 0" />
                        <inertial mass="2.34"
                            pos="0.0004 -0.0047 -0.090"
                            fullinertia="0.0037 0.0036 0.0016 0 0 0" />
                        <body name="forearm_r"
                              pos="-0.0036 0.0283 -0.0989"
                              euler="0 0 0">
                            <joint name="elbow_pitch_r" type="hinge"
                                axis="1.0 0.0 0.0"
                                pos="-0.0283 -0.0345 -0.0010"
                                range="-2.5307 0.0000" limited="true" />
                            <geom name="forearm_r_geom" type="mesh" mesh="forearm_r" pos="0 0 0" euler="0 0 0" />
                            <inertial mass="0.47"
                                pos="0.0031 -0.0339 -0.102"
                                fullinertia="0.0012 0.0013 0.0003 0 0 0" />
                        </body>
                    </body>
                </body>
            </body>

            <body name="shoulder_pitch_l"
                  pos="-0.2215 -0.0042 0.3135"
                  euler="3.141592653589793 0 0">
                <joint name="shoulder_pitch_l" type="hinge"
                    axis="1.0 0.0 0.0"
                    pos="0.0755 -0.0042 0.0240"
                    range="-3.1416 3.1416" limited="true" />
                <geom name="shoulder_pitch_l_geom" type="mesh" mesh="shoulder_pitch_l" pos="0 0 0" euler="0 0 0" />
                <inertial mass="3.68"
                    pos="0.002 -0.0019 0.024"
                    fullinertia="0.0032 0.0049 0.0036 0 0 0" />
                <body name="shoulder_roll_l"
                      pos="0 -0.0022 0.1313"
                      euler="3.1415926535897927 0 1.5707963267950065">
                    <joint name="shoulder_roll_l" type="hinge"
                        axis="1.0 0.0 0.0"
                        pos="0.0422 0 0.1073"
                        range="-0.0873 3.3161" limited="true" />
                    <geom name="shoulder_roll_l_geom" type="mesh" mesh="shoulder_roll_l" pos="0 0 0" euler="0 0 0" />
                    <inertial mass="1.74"
                        pos="0.0003 0 0.025"
                        fullinertia="0.0013 0.0017 0.0015 0 0 0" />
                    <body name="bicep_l"
                          pos="-0.0061 0 -0.035"
                          euler="0 0 1.5707963267948972">
                        <joint name="elbow_yaw_l" type="hinge"
                            axis="0.0 0.0 -1.0"
                            pos="0 -0.0061 0.031"
                            range="-3.1416 3.1416" limited="true" />
                        <geom name="bicep_l_geom" type="mesh" mesh="bicep_l" pos="0 0 0" euler="0 0 0" />
                        <inertial mass="2.34"
                            pos="0.0004 -0.0047 -0.090"
                            fullinertia="0.0037 0.0036 0.0016 0 0 0" />
                        <body name="forearm_l"
                              pos="-0.0036 0.0283 -0.0989"
                              euler="0 0 0">
                            <joint name="elbow_pitch_l" type="hinge"
                                axis="-1.0 0.0 0.0"
                                pos="-0.0283 -0.0345 -0.0010"
                                range="-2.5307 0.0000" limited="true" />
                            <geom name="forearm_l_geom" type="mesh" mesh="forearm_l" pos="0 0 0" euler="0 0 0" />
                            <inertial mass="0.47"
                                pos="0.0031 -0.0339 -0.102"
                                fullinertia="0.0012 0.0013 0.0003 0 0 0" />
                        </body>
                    </body>
                </body>
            </body>

        </body>
    </worldbody>

    <actuator>
        <!-- position servos for ros2_control position interface -->
        <!-- NOTE: kv must be omitted - MujocoSystem identifies position actuators -->
        <!-- by checking biasprm[2]==0. kv sets biasprm[2]=-kv, breaking detection. -->
        <!-- Joint-level damping (damping="10") provides velocity damping instead. -->
        <position name="shoulder_pitch_r" joint="shoulder_pitch_r" kp="1500" />
        <position name="shoulder_roll_r"  joint="shoulder_roll_r"  kp="1500" />
        <position name="elbow_yaw_r"      joint="elbow_yaw_r"      kp="400"  />
        <position name="elbow_pitch_r"    joint="elbow_pitch_r"    kp="200"  />
        <position name="shoulder_pitch_l" joint="shoulder_pitch_l" kp="1500" />
        <position name="shoulder_roll_l"  joint="shoulder_roll_l"  kp="1500" />
        <position name="elbow_yaw_l"      joint="elbow_yaw_l"      kp="400"  />
        <position name="elbow_pitch_l"    joint="elbow_pitch_l"    kp="200"  />
    </actuator>

</mujoco>
