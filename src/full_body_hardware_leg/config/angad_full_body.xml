    <!-- ═══════════════════════════════════════════════════════
       ACTUATORS
       Position actuators are required by mujoco_ros2_control.
       kp is the position servo stiffness [N·m/rad].
       Joint-level damping (default: 5 N·m·s/rad) acts as kd.

       Tuning guide:
         kp_hip/knee   ≈ 1000–2000  (heavy joints, high torque)
         kp_ankle      ≈ 500–800    (moderate, need compliance)
         kp_torso      ≈ 800        (yaw — lighter load)
         kp_shoulder   ≈ 800–1200   (arm weight ~3 kg)
         kp_elbow      ≈ 300–500    (lighter distal)
  ═══════════════════════════════════════════════════════ -->
    <actuator>
        <!-- ── Lower body ── -->
        <position name="hip_pitch_r" joint="hip_pitch_r" kp="1500" />
        <position name="hip_roll_r" joint="hip_roll_r" kp="1200" />
        <position name="thigh_yaw_r" joint="thigh_yaw_r" kp="800" />
        <position name="knee_pitch_r" joint="knee_pitch_r" kp="1800" />
        <position name="ankle_pitch_r" joint="ankle_pitch_r" kp="600" />
        <position name="ankle_roll_r" joint="ankle_roll_r" kp="400" />

        <position name="hip_pitch_l" joint="hip_pitch_l" kp="1500" />
        <position name="hip_roll_l" joint="hip_roll_l" kp="1200" />
        <position name="thigh_yaw_l" joint="thigh_yaw_l" kp="800" />
        <position name="knee_pitch_l" joint="knee_pitch_l" kp="1800" />
        <position name="ankle_pitch_l" joint="ankle_pitch_l" kp="600" />
        <position name="ankle_roll_l" joint="ankle_roll_l" kp="400" />

        <!-- ── Torso ── -->
        <position name="torso_yaw" joint="torso_yaw" kp="800" />

        <!-- ── Upper body ── -->
        <position name="shoulder_pitch_r" joint="shoulder_pitch_r" kp="1000" />
        <position name="shoulder_roll_r" joint="shoulder_roll_r" kp="1000" />
        <position name="elbow_yaw_r" joint="elbow_yaw_r" kp="400" />
        <position name="elbow_pitch_r" joint="elbow_pitch_r" kp="300" />

        <position name="shoulder_pitch_l" joint="shoulder_pitch_l" kp="1000" />
        <position name="shoulder_roll_l" joint="shoulder_roll_l" kp="1000" />
        <position name="elbow_yaw_l" joint="elbow_yaw_l" kp="400" />
        <position name="elbow_pitch_l" joint="elbow_pitch_l" kp="300" />
    </actuator>

