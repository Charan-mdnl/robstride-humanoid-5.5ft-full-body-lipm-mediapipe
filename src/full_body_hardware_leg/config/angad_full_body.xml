        <force name="contact_force_r_toe_1" site="foot_r_toe_site" />
        <force name="contact_force_r_toe_2" site="foot_r_toe_site_2" />
        <force name="contact_force_r_heel_1" site="foot_r_heel_site" />
        <force name="contact_force_r_heel_2" site="foot_r_heel_site_2" />

        <!-- Removed center foot force sensor for left foot -->
        <force name="contact_force_l_toe_1" site="foot_l_toe_site" />
        <force name="contact_force_l_toe_2" site="foot_l_toe_site_2" />
        <force name="contact_force_l_heel_1" site="foot_l_heel_site" />
        <force name="contact_force_l_heel_2" site="foot_l_heel_site_2" />
    </sensor>

    <!-- ═══════════════════════════════════════════════════════
       KEYFRAME  — initial standing pose
       qpos order: freejoint(7) then joints in XML tree order:
         hip_pitch_r  hip_roll_r  thigh_yaw_r  knee_pitch_r  ankle_pitch_r  ankle_roll_r
         hip_pitch_l  hip_roll_l  thigh_yaw_l  knee_pitch_l  ankle_pitch_l  ankle_roll_l
         torso_yaw
         shoulder_pitch_r  shoulder_roll_r  elbow_yaw_r  elbow_pitch_r
         shoulder_pitch_l  shoulder_roll_l  elbow_yaw_l  elbow_pitch_l
       ctrl order mirrors actuator order (same as joints above).
       Standing crouch: hip −5°, knee −15°, ankle +10° to keep CoM centred.
  ═══════════════════════════════════════════════════════ -->
    <keyframe>
        <key name="standing"
            qpos="0 0 0.76  1 0 0 0
                  0 0 0  -0.05  0  0
                  0 0 0  -0.05  0  0
                  0
                  0  0.3  0  0
                  0 -0.3  0  0"
            ctrl="0 0 0  -0.05  0  0
                  0 0 0  -0.05  0  0
                  0
                  0  0.3  0  0
                  0 -0.3  0  0" />
        <key name="crouching"
            qpos="0 0 0.70  1 0 0 0
                0 0 0  -0.25  0  0
                0 0 0  -0.25  0  0
                0
                0  0.15  0  0
                0 -0.15  0  0"
            ctrl="0 0 0  -0.25  0  0
                0 0 0  -0.25  0  0
                0
                0  0.15  0  0
                0 -0.15  0  0" />
    </keyframe>

