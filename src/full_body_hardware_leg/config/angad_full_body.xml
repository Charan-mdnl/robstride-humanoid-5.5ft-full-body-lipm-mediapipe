                                <body name="foot_l"
                                    pos="-0.02350 -1.06581e-15 0.03099"
                                    euler="-3.14159265359 1.38778e-17 -1.5707963">
                                    <joint name="ankle_roll_l" type="hinge"
                                        axis="-2.73553e-15 -1.0 -2.98778e-11"
                                        pos="-4.43319e-07 0.04050 0.03099"
                                        range="-0.3491 0.3491" limited="true" />

                                    <geom name="foot_l_vis" class="visual_only"
                                        type="mesh" mesh="foot_l" pos="0 0 0" euler="0 0 0" />

                                    <geom name="foot_l_heel"
                                        class="foot_contact"
                                        type="capsule" size="0.018 0.028"
                                        pos="0.0 -0.048 -0.009"
                                        euler="0 1.5708 0" />
                                    <geom name="foot_l_toe"
                                        class="foot_contact"
                                        type="capsule" size="0.018 0.028"
                                        pos="0.0 0.075 -0.009"
                                        euler="0 1.5708 0" />

                                    <inertial mass="0.365"
                                        pos="-6.58e-11 0.02074 -4.79e-04"
                                        fullinertia="8.31e-04 2.79e-04 9.48e-04 0 0 0" />
                                    <site name="foot_l_site" pos="0 0.015 -0.009" size="0.01" />
                                    <site name="foot_l_toe_site" pos="0 0.075 -0.009"
                                        euler="0 0 0" size="0.01" />
                                    <site name="foot_l_toe_site_2" pos="0.035 0.075 -0.009"
                                        euler="0 0 0" size="0.01" />
                                    <site name="foot_l_toe_site_3" pos="-0.035 0.075 -0.009"
                                        euler="0 0 0" size="0.01" />
                                    <site name="foot_l_heel_site" pos="0 -0.048 -0.009"
                                        euler="0 0 0" size="0.01" />
                                    <site name="foot_l_heel_site_2" pos="0.035 -0.048 -0.009"
                                        euler="0 0 0" size="0.01" />
                                    <site name="foot_l_heel_site_3" pos="-0.035 -0.048 -0.009"
                                        euler="0 0 0" size="0.01" />
                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>

            <!-- ── TORSO (waist yaw joint) ── -->
