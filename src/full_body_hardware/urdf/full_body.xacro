<?xml version="1.0"?>
<!--
  full_body.xacro
  ================
  Minimal URDF description of the full Angad humanoid for:
    • robot_state_publisher  (TF tree / RViz)
    • ros2_control hardware registration (mujoco_ros2_control/MujocoSystem)

  This file is NOT used for collision or physics — those are handled by
  angad_full_body.xml fed to mujoco_ros2_control.

  Joint names and parent-child hierarchy MUST match angad_full_body.xml.

  Mesh paths reference the XP_robot package meshes so RViz can display them.
-->
<robot name="angad_full_body" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Find the mesh directory via the upper_body package (which has XP_robot meshes fallback) -->
    <!-- For the RSP we use the XP_robot path directly -->
    <xacro:property name="xp_mesh" value="file:////home/a/humanoid_ws/src/XP_robot/meshes" />
    <xacro:arg name="use_real_hardware" default="false" />

    <material name="silver">
        <color rgba="0.7 0.7 0.7 1.0" />
    </material>

    <!-- Dummy root link for KDL / MoveIt.
         Physics still comes from MuJoCo, so this only affects the URDF tree. -->
    <link name="base_link" />

    <joint name="base_link_to_pelvis" type="fixed">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <parent link="base_link" />
        <child link="pelvis" />
    </joint>

    <!-- ══════════════════════════════════════════════════
       PELVIS  (free root in MuJoCo; dummy parent only for URDF/KDL)
  ══════════════════════════════════════════════════ -->
    <link name="pelvis">
        <inertial>
            <origin xyz="0 0 0.109" rpy="0 0 0" />
            <mass value="5.565" />
            <inertia ixx="0.06430" iyy="0.07731" izz="0.04267"
                ixy="0" iyz="0" ixz="0" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="${xp_mesh}/pelvis.stl" scale="0.001 0.001 0.001" />
            </geometry>
            <material name="silver" />
        </visual>
        <collision>
            <origin xyz="0 0 0.06" rpy="0 0 0" />
            <geometry>
                <box size="0.16 0.24 0.24" />
            </geometry>
        </collision>
    </link>

    <!-- ══ RIGHT LEG ══ -->
    <link name="hip_pitch_r">
        <inertial>
            <origin xyz="-8e-05 0.00346 0.07278" rpy="0 0 0" />
            <mass value="1.008" />
            <inertia ixx="0.00415" iyy="0.00587" izz="0.00350" ixy="0" iyz="0" ixz="0" />
        </inertial>
        <visual>
