            </geometry>
            <material name="silver" />
        </visual>
        <collision>
            <origin xyz="0 0 0.06" rpy="0 0 0" />
            <geometry>
                <cylinder radius="0.035" length="0.10" />
            </geometry>
        </collision>
    </link>
    <joint name="hip_pitch_r" type="revolute">
        <origin xyz="-0.074290 0.000000 0.065550" rpy="-3.141593 -1.308997 -3.141593" />
        <parent link="pelvis" />
        <child link="hip_pitch_r" />
        <axis xyz="0 0 -1" />
        <limit lower="-3.1416" upper="3.1416" effort="150" velocity="5" />
        <dynamics damping="5.0" friction="0.1" />
